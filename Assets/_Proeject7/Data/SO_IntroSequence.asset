  m_Script: {fileID: 11500000, guid: db218d9ba02843b6968cccc636b49ecf, type: 3}
  m_Name: SO_IntroSequence
  m_EditorClassIdentifier: Assembly-CSharp::SO_IntroSequence
  _lines:
  - "\uB3C5\uC7AC \uC815\uBD80\uAC00 \uBB3C\uB7EC\uB098\uACE0 \uC0C8 \uC815\uBD80\uAC00
    \uB4E4\uC5B4\uC130\uC2B5\uB2C8\uB2E4."
  - "\uD55C \uB2EC \uC804, \uC0C8 \uC815\uBD80\uB294 \uC815\uBCF4\uACF5\uAC1C\uAE30\uAD00\uC744
    \uC2E0\uC124\uD588\uC2B5\uB2C8\uB2E4."
  - "\uB2F9\uC2E0\uC740 \uC81C5\uB300 \uC815\uBCF4\uACF5\uAC1C \uB2F4\uB2F9\uAD00\uC73C\uB85C
    \uC784\uBA85\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
  - "\uC804\uC784\uC790 \uB124 \uBA85\uC740 \uBAA8\uB450 \uC2E4\uC885\uB418\uC5C8\uC2B5\uB2C8\uB2E4."
  - "\uC5C5\uBB34\uB97C \uC2DC\uC791\uD558\uC138\uC694."
  - "* \uC62C\uBC14\uB974\uC9C0 \uC54A\uC740 \uAE30\uAD00\uC5D0 \uC811\uC218 \uAC74\uC744
    \uBC30\uC815\uD558\uBA74 \uD574\uB2F9 \uAE30\uAD00\uACFC\uC758 \uAD00\uACC4\uB3C4\uAC00
    \uAC10\uC18C\uD569\uB2C8\uB2E4."
  - "* \uACF5\uAC1C\uD574\uC11C\uB294 \uC548 \uB418\uB294 \uC694\uCCAD\uC744 \uC811\uC218\uD558\uBA74
    \uC5C5\uBB34 \uC2E0\uB8B0\uB3C4\uAC00 \uAC10\uC18C\uD569\uB2C8\uB2E4."
  - "* \uACF5\uAC1C \uAC00\uB2A5\uD55C \uC694\uCCAD\uC744 \uAE30\uAC01\uD558\uBA74
    \uC5C5\uBB34 \uC2E0\uB8B0\uB3C4\uAC00 \uAC10\uC18C\uD569\uB2C8\uB2E4."
  - "* \uAE30\uAC01 \uC0AC\uC720\uB97C \uC798\uBABB \uC120\uD0DD\uD558\uBA74 \uC5C5\uBB34
    \uC2E0\uB8B0\uB3C4\uAC00 \uAC10\uC18C\uD558\uACE0, \uAD00\uB828 \uAE30\uAD00\uACFC\uC758
    \uAD00\uACC4\uB3C4\uB3C4 \uAC10\uC18C\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - "* \uBCF4\uB958\uD55C \uC694\uCCAD\uC740 \uB2E4\uC74C \uB0A0 \uB2E4\uC2DC \uC62C\uB77C\uC624\uBA70,
    \uCD5C\uC885 \uD3C9\uAC00\uC5D0 \uBD88\uB9AC\uD558\uAC8C \uC791\uC6A9\uD569\uB2C8\uB2E4."
  - "* \uAE30\uD55C\uC774 \uC5BC\uB9C8 \uB0A8\uC9C0 \uC54A\uC740 \uC694\uCCAD\uC740
    \uBCF4\uB958\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
  - "* \uBCF4\uC644\uC694\uAD6C\uB97C \uD558\uBA74 \uD6C4\uC18D \uC694\uCCAD\uC11C\uAC00
    \uB2E4\uC2DC \uB4E4\uC5B4\uC62C \uC218 \uC788\uC2B5\uB2C8\uB2E4."
