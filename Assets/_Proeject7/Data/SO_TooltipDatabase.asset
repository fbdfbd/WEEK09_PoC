  m_Script: {fileID: 11500000, guid: 729ad1438f2846fd92861b6114921592, type: 3}
  m_Name: SO_TooltipDatabase
  m_EditorClassIdentifier: Assembly-CSharp::SO_TooltipDatabase
  _entries:
  - _key: 1
    _text: "\uC694\uAC74\uC744 \uAC16\uCD98 \uC815\uBCF4\uACF5\uAC1C \uC694\uCCAD\uC744
      \uC815\uC2DD \uC811\uC218\uD569\uB2C8\uB2E4. \n\uC811\uC218\uB41C \uC694\uCCAD\uC740
      \uC774\uD6C4 \uAD00\uACC4\uAE30\uAD00\uC5D0 \uBC30\uC815\uD574\uC57C \uD569\uB2C8\uB2E4."
  - _key: 2
    _text: "\uC694\uCCAD \uB0B4\uC6A9\uC774 \uBD88\uBA85\uD655\uD558\uAC70\uB098
      \uD2B9\uC815\uC774 \uBD80\uC871\uD560 \uB54C \uBCF4\uC644\uC744 \uC694\uAD6C\uD569\uB2C8\uB2E4.
      \n\uBCF4\uC644\uB41C \uC694\uCCAD\uC11C\uB294 \uC774\uD6C4 \uB2E4\uC2DC \uC811\uC218\uB420
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - _key: 3
    _text: "\uAE30\uD55C\uC774 \uB0A8\uC544 \uC788\uB294 \uC694\uCCAD\uC758 \uCC98\uB9AC\uB97C
      \uB2E4\uC74C \uADFC\uBB34\uC77C\uB85C \uBBF8\uB8F9\uB2C8\uB2E4. \n\uBC18\uBCF5\uB41C
      \uBCF4\uB958\uB294 \uCD5C\uC885 \uD3C9\uAC00\uC5D0 \uBD88\uB9AC\uD558\uAC8C
      \uAE30\uB85D\uB420 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - _key: 4
    _text: "\uBC95\uC815 \uBE44\uACF5\uAC1C \uC0AC\uC720\uAC00 \uC788\uB294 \uC694\uCCAD\uC744
      \uAC70\uBD80\uD569\uB2C8\uB2E4. \n\uAE30\uAC01 \uC2DC \uC0AC\uC720\uB97C \uC120\uD0DD\uD574\uC57C
      \uD558\uBA70, \uBD80\uB2F9\uD55C \uAE30\uAC01\uC740 \uC2E0\uB8B0\uB97C \uD6FC\uC190\uD569\uB2C8\uB2E4."
  - _key: 5
    _text: "\uAC1C\uC778\uC758 \uC2E0\uC0C1, \uC5F0\uB77D\uCC98, \uC704\uCE58, \uC0AC\uC0DD\uD65C
      \uC815\uBCF4\uAC00 \uD3EC\uD568\uB41C \uACBD\uC6B0 \uC801\uC6A9\uD569\uB2C8\uB2E4.
      \n\uACF5\uC775\uC131\uC774 \uD070 \uC0AC\uC548\uC5D0\uB294 \uC2E0\uC911\uD788
      \uC801\uC6A9\uD574\uC57C \uD569\uB2C8\uB2E4."
  - _key: 6
    _text: "\uACBD\uACC4, \uBCF4\uC548, \uD1B5\uC81C\uC120, \uC2DC\uC124 \uBC29\uD638
      \uB4F1 \uC548\uBCF4\uC0C1 \uBBFC\uAC10\uD55C \uC815\uBCF4\uAC00 \uD3EC\uD568\uB41C
      \uACBD\uC6B0 \uC801\uC6A9\uD569\uB2C8\uB2E4."
