  id: report_poc9_deep_inspection
  title: "\uC2EC\uCE35 \uAC10\uCC30 \uBCF4\uACE0\uC11C"
  summary: "\uC138\uC778\uD56D \uC7AC\uAC1C\uBC1C \uC0AC\uC5C5\uC758 \uC790\uAE08
    \uD750\uB984, \uB0B4\uBD80 \uC2B9\uC778 \uC808\uCC28, \uC775\uBA85 \uC81C\uBCF4\uC790
    \uC99D\uC5B8\uC744 \uBB36\uC740 \uB2E8\uC77C \uBCF4\uACE0\uC11C."
  paragraphs:
  - id: p01_contract
    title: "\uACC4\uC57D \uAD6C\uC870"
    originalText: "\uC138\uC778\uD56D \uC7AC\uAC1C\uBC1C 2\uCC28 \uACC4\uC57D\uC740
      \uACF5\uAC1C \uC785\uCC30 \uD615\uC2DD\uC744 \uCDE8\uD588\uC9C0\uB9CC, \uCD5C\uC885
      \uC2EC\uC0AC\uD45C\uB294 \uC138 \uACF3\uC758 \uD3C9\uAC00\uC704\uC6D0 \uC11C\uBA85\uC774
      \uBE60\uC9C4 \uC0C1\uD0DC\uB85C \uBCF4\uAD00\uB418\uC5B4 \uC788\uC5C8\uB2E4."
    informationValue: 5
    sensitivity: 3
    tags: 000000000200000006000000
    editOptions:
    - id: p01_partial_mask
      label: "\uD3C9\uAC00\uC704\uC6D0 \uC815\uBCF4\uB97C \uAC00\uB9B0\uB2E4"
      actionType: 1
      resultingText: "\uC138\uC778\uD56D \uC7AC\uAC1C\uBC1C 2\uCC28 \uACC4\uC57D\uC740
        \uACF5\uAC1C \uC785\uCC30 \uD615\uC2DD\uC744 \uCDE8\uD588\uC9C0\uB9CC, \uCD5C\uC885
        \uC2EC\uC0AC\uD45C\uB294 \uC77C\uBD80 \uD3C9\uAC00\uC704\uC6D0 \uC815\uBCF4\uAC00
        \uAC00\uB824\uC9C4 \uC0C1\uD0DC\uB85C \uBCF4\uAD00\uB418\uC5B4 \uC788\uC5C8\uB2E4."
      integrityDelta: -15
      exposureDelta: -1
      distortionPenalty: 0
    - id: p01_full_mask
      label: "\uACC4\uC57D \uB2E8\uB77D \uC804\uCCB4\uB97C \uAC00\uB9B0\uB2E4"
      actionType: 2
      resultingText: "[\uACC4\uC57D \uAD6C\uC870 \uAD00\uB828 \uB2E8\uB77D \uC804\uCCB4
        \uBE44\uACF5\uAC1C]"
      integrityDelta: -80
      exposureDelta: -3
      distortionPenalty: 0
    - id: p01_rewrite_preserve
      label: "\uC808\uCC28\uC0C1 \uC758\uBB38\uC73C\uB85C \uC644\uD654\uD55C\uB2E4"
      actionType: 3
      resultingText: "\uC138\uC778\uD56D \uC7AC\uAC1C\uBC1C 2\uCC28 \uACC4\uC57D\uC758
        \uCD5C\uC885 \uC2EC\uC0AC\uD45C\uC5D0\uB294 \uC77C\uBD80 \uC808\uCC28\uC0C1
        \uD655\uC778\uC774 \uD544\uC694\uD55C \uACF5\uBC31\uC774 \uB0A8\uC544 \uC788\uC5C8\uB2E4."
      integrityDelta: -20
      exposureDelta: -1
      distortionPenalty: 5
    - id: p01_rewrite_distort
      label: "\uC815\uC0C1 \uC2EC\uC0AC\uB85C \uACE0\uCCD0 \uC4F4\uB2E4"
      actionType: 4
      resultingText: "\uC138\uC778\uD56D \uC7AC\uAC1C\uBC1C 2\uCC28 \uACC4\uC57D\uC740
        \uACF5\uAC1C \uC785\uCC30\uACFC \uC815\uC2DD \uC2EC\uC0AC\uB97C \uAC70\uCCD0
        \uBB38\uC81C \uC5C6\uC774 \uBCF4\uAD00\uB418\uC5C8\uB2E4."
      integrityDelta: -70
      exposureDelta: -2
      distortionPenalty: 35
  - id: p02_transfer
    title: "\uC790\uAE08 \uC774\uCCB4"
    originalText: "\uACC4\uC57D \uCCB4\uACB0 \uC774\uD2C0 \uC804, \uC2DC\uD589\uC0AC
      \uBCF4\uC870 \uACC4\uC88C\uC5D0\uC11C \uC2DC\uC7A5 \uBE44\uC11C\uC2E4 \uAD00\uACC4\uC790\uC758
      \uAC00\uC871 \uD68C\uC0AC\uB85C 4\uC5B5 2\uCC9C\uB9CC \uC6D0\uC774 \uC774\uCCB4\uB418\uC5C8\uB2E4."
    informationValue: 5
    sensitivity: 5
    tags: 000000000100000002000000
    editOptions:
    - id: p02_partial_mask
      label: "\uAE08\uC561\uACFC \uAC00\uC871 \uD68C\uC0AC\uB97C \uAC00\uB9B0\uB2E4"
      actionType: 1
      resultingText: "\uACC4\uC57D \uCCB4\uACB0 \uC774\uD2C0 \uC804, \uC2DC\uD589\uC0AC
