      exposureDelta: -5
      distortionPenalty: 0
    - id: p02_rewrite_preserve
      label: "관계성을 약하게 표현한다"
      actionType: 3
      resultingText: "계약 직전 시행사 보조 계좌에서 공직자 주변 인물과 관련된 법인으로 상당한 자금이 이동한 정황이 확인되었다."
      integrityDelta: -15
