      integrityDelta: -20
      exposureDelta: -2
      distortionPenalty: 0
    - id: p02_full_mask
      label: "\uC790\uAE08 \uC774\uCCB4 \uB2E8\uB77D \uC804\uCCB4\uB97C \uAC00\uB9B0\uB2E4"
