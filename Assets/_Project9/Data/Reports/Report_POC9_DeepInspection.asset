      exposureDelta: -5
      distortionPenalty: 0
    - id: p02_rewrite_preserve
      label: "\uAD00\uACC4\uC131\uC744 \uC57D\uD558\uAC8C \uD45C\uD604\uD55C\uB2E4"
      actionType: 3
      resultingText: "\uACC4\uC57D \uC9C1\uC804 \uC2DC\uD589\uC0AC \uBCF4\uC870 \uACC4\uC88C\uC5D0\uC11C
        \uACF5\uC9C1\uC790 \uC8FC\uBCC0 \uC778\uBB3C\uACFC \uAD00\uB828\uB41C \uBC95\uC778\uC73C\uB85C
        \uC0C1\uB2F9\uD55C \uC790\uAE08\uC774 \uC774\uB3D9\uD55C \uC815\uD669\uC774
        \uD655\uC778\uB418\uC5C8\uB2E4."
      integrityDelta: -15
      exposureDelta: -1
      distortionPenalty: 5
    - id: p02_rewrite_distort
      label: "\uC815\uC0C1 \uAC70\uB798\uCC98\uB7FC \uBC14\uAFBC\uB2E4"
      actionType: 4
      resultingText: "\uACC4\uC57D \uC9C1\uC804 \uC2DC\uD589\uC0AC \uBCF4\uC870 \uACC4\uC88C\uC5D0\uC11C\uB294
        \uD1B5\uC0C1\uC801\uC778 \uC815\uC0B0 \uBAA9\uC801\uC758 \uBC95\uC778 \uAC04
        \uAC70\uB798\uB9CC \uD655\uC778\uB418\uC5C8\uB2E4."
      integrityDelta: -85
      exposureDelta: -4
      distortionPenalty: 45
  - id: p03_whistleblower
    title: "\uC81C\uBCF4\uC790 \uC9C4\uC220"
    originalText: "\uC775\uBA85 \uC81C\uBCF4\uC790\uB294 \uC2EC\uC0AC \uC804\uB0A0
      \uBE44\uACF5\uC2DD \uD68C\uC758\uC5D0\uC11C \uB099\uCC30 \uC5C5\uCCB4\uAC00
      \uC774\uBBF8 \uACB0\uC815\uB418\uC5C8\uB2E4\uB294 \uB9D0\uC744 \uB4E4\uC5C8\uB2E4\uACE0
